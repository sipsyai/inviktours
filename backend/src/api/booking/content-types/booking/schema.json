{
  "kind": "collectionType",
  "collectionName": "bookings",
  "info": {
    "singularName": "booking",
    "pluralName": "bookings",
    "displayName": "Booking",
    "description": "Tour booking/reservation system"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "tour": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tour.tour",
      "inversedBy": "bookings"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "bookings"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "confirmed", "cancelled", "completed"],
      "default": "pending",
      "required": true
    },
    "numberOfParticipants": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "participantDetails": {
      "type": "json",
      "required": false
    },
    "contactName": {
      "type": "string",
      "required": true
    },
    "contactEmail": {
      "type": "email",
      "required": true
    },
    "contactPhone": {
      "type": "string",
      "required": true
    },
    "specialRequests": {
      "type": "text"
    },
    "totalPrice": {
      "type": "decimal",
      "required": false
    },
    "currency": {
      "type": "string",
      "default": "TRY"
    },
    "bookingReference": {
      "type": "uid",
      "targetField": "contactEmail"
    },
    "paymentStatus": {
      "type": "enumeration",
      "enum": ["unpaid", "partial", "paid", "refunded"],
      "default": "unpaid"
    },
    "notes": {
      "type": "text"
    }
  }
}
